<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="#F7F3EF">

    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:padding="24dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:backgroundTint="#6F50B5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <TextView

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:text="Wardrobe Analytics"

            android:textSize="30sp"

            android:textStyle="bold"

            android:textColor="#222222"

            android:layout_marginBottom="20dp" />

        <TextView

            android:id="@+id/txtTotalItems"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:text="Total clothing items: 0"

            android:textSize="18sp"

            android:textColor="#222222"

            android:layout_marginBottom="12dp" />

        <TextView

            android:id="@+id/txtTotalPlans"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:text="Total outfit plans: 0"

            android:textSize="18sp"

            android:textColor="#222222"

            android:layout_marginBottom="12dp" />

        <TextView

            android:id="@+id/txtCategoryCounts"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:text="Category counts:"

            android:textSize="18sp"

            android:textColor="#222222"

            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
