<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="false"
    android:background="#F7F3EF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="120dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:text="← Back"
            android:backgroundTint="#6F50B5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Clothing Item"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="18dp" />

        <ImageView
            android:id="@+id/imgClothing"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#E5E0DA"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_gallery"
            android:contentDescription="Clothing item image"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnChooseImage"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Choose Photo"
            android:backgroundTint="#6F50B5"
            android:textColor="#FFFFFF" />

        <EditText
            android:id="@+id/edtName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Item name"
            android:inputType="textCapWords"
            android:autofillHints="name"
            android:layout_marginTop="14dp"
            android:textColor="#222222"
            android:textColorHint="#777777"/>

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/spinnerColor"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/spinnerSeason"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/spinnerStyle"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/spinnerOccasion"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnSaveClothing"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Clothing Item"
            android:backgroundTint="#6F50B5"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>